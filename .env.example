# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Postgres connection string (required). Chat history, auth, and projects.
# e.g. postgres://user:password@host:5432/dbname
POSTGRES_URL=****

# Brave Search API key (required for the bundled brave-search skill).
# Get one at https://api-dashboard.search.brave.com/
BRAVE_API_KEY=****

# Optional: Redis connection string. Enables IP rate limiting when set.
# REDIS_URL=****

# Optional: blob storage for file uploads (Vercel Blob).
# BLOB_READ_WRITE_TOKEN=****

# Optional: override where bundled skills are loaded from (defaults to <repo>/skills).
# PI_CHATBOT_SKILLS_DIR=/opt/pi-chatbot/skills

# Optional: override the per-user workspace root (defaults to ~/.pi-chatbot).
# PI_CHATBOT_HOME=/var/lib/pi-chatbot
